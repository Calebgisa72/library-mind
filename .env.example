# =============================================================================
# LibraryMind — Example environment configuration
#
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. Never commit real secrets.
#
# At least ONE provider key must be set for the application to start
# (validated in app/core/settings.py).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=LibraryMind
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json              # json | console

# -----------------------------------------------------------------------------
# AI providers — supply at least one key
# Provider order is controlled by PRIMARY_PROVIDER; on failure, the resilient
# orchestrator falls through to the remaining configured providers.
# -----------------------------------------------------------------------------
PRIMARY_PROVIDER=openai      # openai | anthropic | amaliai

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-latest

AMALIAI_API_KEY=
AMALIAI_BASE_URL=https://api.amalitech.org/v1
AMALIAI_CHAT_MODEL=

# -----------------------------------------------------------------------------
# Vector store (ChromaDB — local persistent client)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=books
RAG_TOP_K=4
# RAG_RELEVANCE_THRESHOLD is a SIMILARITY threshold in [0.0, 1.0]:
#   0.0 = unrelated, 1.0 = identical.
# ChromaDB returns cosine *distance* (0=identical, 2=opposite); the RAG
# engine converts it via `similarity = 1 - distance` before this filter.
# 0.35 is a sensible starting point for short book descriptions; raise
# for stricter retrieval, lower if results are too sparse.
RAG_RELEVANCE_THRESHOLD=0.35

# -----------------------------------------------------------------------------
# Cache (Redis — optional; application degrades gracefully if unavailable)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL_SECONDS=3600
CACHE_ENABLED=true

# -----------------------------------------------------------------------------
# Rate limiting (token-bucket per process)
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# Cost controls
# -----------------------------------------------------------------------------
# Soft daily budget cap in USD. 0.0 disables the cap (usage is still tracked
# and exposed via /health). When non-zero, /health reports daily_cost_usd
# against this limit and later phases log a warning when nearing it.
BUDGET_DAILY_LIMIT_USD=0.0

# -----------------------------------------------------------------------------
# Chatbot
# -----------------------------------------------------------------------------
CHAT_HISTORY_MAX_MESSAGES=10
CHAT_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# CORS (comma-separated list of allowed origins for the future frontend)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
